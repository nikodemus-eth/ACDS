{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GRITS Run Request",
  "description": "Request to initiate a GRITS integrity evaluation run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "target_id",
    "trigger_type",
    "suite_ids",
    "baseline_ref",
    "reporting_only",
    "requested_at",
    "environment"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "trigger_type": {
      "type": "string",
      "enum": ["manual", "scheduled"]
    },
    "suite_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["smoke", "regression", "drift", "redteam"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "baseline_ref": {
      "type": "string",
      "minLength": 1
    },
    "reporting_only": {
      "type": "boolean",
      "const": true
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object",
      "properties": {
        "python_version": { "type": "string" },
        "os": { "type": "string" },
        "node_id": { "type": "string" },
        "openclaw_root": { "type": "string" }
      }
    }
  }
}
