{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://process-swarm.local/schemas/reduced-assurance-governance-event.schema.json",
  "title": "ReducedAssuranceGovernanceEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "event_id",
    "governance_action_type",
    "reduction_type",
    "assurance_posture_before",
    "assurance_posture_after",
    "reason_summary",
    "affected_artifact_refs",
    "actor_id",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "reduced_assurance_governance_event"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+)*$"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "governance_action_type": {
      "type": "string",
      "enum": [
        "proposal_review",
        "plan_approval",
        "lease_approval",
        "publish_approval",
        "delivery_approval",
        "policy_waiver",
        "emergency_override",
        "other"
      ]
    },
    "reduction_type": {
      "type": "string",
      "enum": [
        "author_reviewer_role_collapse",
        "reviewer_publisher_role_collapse",
        "single_operator_path",
        "review_depth_reduction",
        "emergency_governance_path",
        "staffing_constraint",
        "time_constrained_operation",
        "other"
      ]
    },
    "assurance_posture_before": {
      "type": "string",
      "const": "standard"
    },
    "assurance_posture_after": {
      "type": "string",
      "const": "reduced"
    },
    "reason_summary": {
      "type": "string",
      "minLength": 1
    },
    "reason_details": {
      "type": "string"
    },
    "normal_expected_governance": {
      "type": "string"
    },
    "actual_governance_path": {
      "type": "string"
    },
    "compensating_controls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "affected_run_ref": {
      "type": "string"
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warning_record_ref": {
      "type": "string"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_role": {
      "type": "string"
    },
    "acknowledged_by": {
      "type": "string"
    },
    "acknowledged_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "record_signature_ref": {
      "type": "string"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
