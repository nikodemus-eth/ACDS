{
  "command_name": "filesystem.read_file",
  "version": "v1",
  "description": "Read the contents of a file from the local filesystem.",
  "side_effect_level": "read_only",
  "supports_dry_run": true,
  "reversible": true,
  "parameters_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Absolute or relative path to the file to read."
      },
      "encoding": {
        "type": "string",
        "default": "utf-8",
        "enum": ["utf-8", "ascii", "latin-1"],
        "description": "Character encoding to use when reading the file."
      },
      "max_bytes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10485760,
        "description": "Maximum number of bytes to read from the file."
      }
    },
    "required": ["path"],
    "additionalProperties": false
  },
  "scope_requirements": {
    "filesystem": true,
    "network": false
  },
  "constraints": {
    "max_bytes": 10485760
  },
  "timeout_seconds": 30
}
