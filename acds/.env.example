# Adaptive Cognitive Dispatch System — Environment Variables
# Copy this file to .env and fill in actual values.

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/acds
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Security
MASTER_KEY_PATH=/path/to/master.key
ENCRYPTION_ALGORITHM=aes-256-gcm
SECRET_ROTATION_INTERVAL_DAYS=90

# Admin Auth
ADMIN_SESSION_SECRET=replace-with-secure-random-value
ADMIN_SESSION_TTL_HOURS=8

# Provider Defaults
DEFAULT_PROVIDER_TIMEOUT_MS=30000
HEALTH_CHECK_INTERVAL_MS=60000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# Worker
WORKER_CONCURRENCY=2
SCORING_JOB_INTERVAL_MS=300000
AGGREGATION_JOB_INTERVAL_MS=600000
