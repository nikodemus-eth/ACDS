{
  "name": "@acds/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Background worker process for recurring ACDS jobs and integrity cadences.",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "node ../../scripts/run-package-tests.mjs worker",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@acds/core-types": "workspace:*",
    "@acds/provider-broker": "workspace:*",
    "@acds/execution-orchestrator": "workspace:*",
    "@acds/audit-ledger": "workspace:*",
    "@acds/evaluation": "workspace:*",
    "@acds/adaptive-optimizer": "workspace:*",
    "@acds/persistence-pg": "workspace:*"
  }
}
