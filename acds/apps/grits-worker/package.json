{
  "name": "@acds/grits-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "description": "Operator-facing GRITS worker and CLI entrypoints for ACDS integrity validation.",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "node ../../scripts/run-package-tests.mjs grits-worker",
    "grits:fast": "tsx src/cli-fixture.ts fast",
    "grits:daily": "tsx src/cli-fixture.ts daily",
    "grits:release": "tsx src/cli-fixture.ts release",
    "grits:pg:fast": "tsx src/cli-pg.ts fast",
    "grits:pg:daily": "tsx src/cli-pg.ts daily",
    "grits:pg:release": "tsx src/cli-pg.ts release",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@acds/grits": "workspace:*",
    "@acds/core-types": "workspace:*",
    "@acds/adaptive-optimizer": "workspace:*",
    "@acds/policy-engine": "workspace:*",
    "@acds/provider-broker": "workspace:*",
    "@acds/audit-ledger": "workspace:*",
    "@acds/execution-orchestrator": "workspace:*",
    "@acds/persistence-pg": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^3.0.0"
  }
}
