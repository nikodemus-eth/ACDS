{
  "name": "@acds/admin-web",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone admin UI for operating ACDS providers, policies, audit, and runtime state.",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "dev:mock": "VITE_USE_MOCKS=true vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "@tanstack/react-query": "^5.51.1",
    "@acds/core-types": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "vite": "^7.1.9"
  }
}
